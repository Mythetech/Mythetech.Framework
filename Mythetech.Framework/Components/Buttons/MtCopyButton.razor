@using MudBlazor
@using Mythetech.Framework
@using Microsoft.JSInterop
@inherits MudComponentBase
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<span id="@_elementId" class="@WrapperClass" data-copied="@_copied.ToString()" data-mt-clipboard>
    <MtIconButton Icon="@CurrentIcon"
                  Tooltip="@CurrentTooltip"
                  TooltipPlacement="@TooltipPlacement"
                  OnClick="@OnCopyClickAsync"
                  Color="@Color"
                  Size="@Size"
                  Variant="@Variant"
                  Disabled="@(Disabled || string.IsNullOrEmpty(Text))"
                  Class="@Class"
                  Style="@Style" />
</span>

@code {
    private const string JsModulePath = "./_content/Mythetech.Framework/mythetech.js";

    private bool _copied;
    private CancellationTokenSource? _resetCts;
    private IJSObjectReference? _jsModule;
    private string? _registeredText;
    private readonly string _elementId = Identifier.Create("mt-cb-");

    [Parameter] public string Text { get; set; } = string.Empty;

    [Parameter] public string CopyTooltip { get; set; } = "Copy";

    [Parameter] public string CopiedTooltip { get; set; } = "Copied";

    [Parameter] public TimeSpan ResetDelay { get; set; } = TimeSpan.FromMilliseconds(1500);

    [Parameter] public Color Color { get; set; } = Color.Default;

    [Parameter] public Size Size { get; set; } = Size.Medium;

    [Parameter] public Variant Variant { get; set; } = Variant.Text;

    [Parameter] public Placement TooltipPlacement { get; set; } = Placement.Bottom;

    [Parameter] public bool Disabled { get; set; }

    private string WrapperClass => _copied ? "mt-copy-button mt-copy-button--copied" : "mt-copy-button";

    private string CurrentIcon => _copied ? MythetechFrameworkIcons.Check : MythetechFrameworkIcons.ContentCopy;

    private string CurrentTooltip => _copied ? CopiedTooltip : CopyTooltip;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", JsModulePath);
            await RegisterTextAsync();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_jsModule is not null && Text != _registeredText)
        {
            await RegisterTextAsync();
        }
    }

    private async Task RegisterTextAsync()
    {
        if (_jsModule is null) return;
        _registeredText = Text;
        await _jsModule.InvokeVoidAsync("registerClipboard", _elementId, Text ?? string.Empty);
    }

    private async Task OnCopyClickAsync()
    {
        if (string.IsNullOrEmpty(Text)) return;

        _resetCts?.Cancel();
        _resetCts?.Dispose();
        _resetCts = new CancellationTokenSource();
        var token = _resetCts.Token;

        _copied = true;
        StateHasChanged();

        try
        {
            await Task.Delay(ResetDelay, token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        _copied = false;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        _resetCts?.Cancel();
        _resetCts?.Dispose();
        _resetCts = null;

        if (_jsModule is not null)
        {
            try
            {
                await _jsModule.InvokeVoidAsync("unregisterClipboard", _elementId);
                await _jsModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }
    }
}
