@using Mythetech.Framework.Infrastructure.Guards
@using Microsoft.JSInterop
@using MudBlazor
@inject IJsGuardService GuardService
@inject IJSRuntime JS

@if (GuardService.IsReady(Name))
{
    <ErrorBoundary @ref="_errorBoundary">
        <ChildContent>
            @ChildContent
        </ChildContent>
        <ErrorContent>
            @if (ErrorContent != null)
            {
                @ErrorContent(context)
            }
            else
            {
                <div class="js-guard-error mud-border-error">
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="Recover"
                                   Class="js-guard-error-retry" />
                    <MudText Typo="Typo.body2" Color="Color.Error">
                        Error loading component
                    </MudText>
                </div>
            }
        </ErrorContent>
    </ErrorBoundary>
}
else if (_timedOut)
{
    @if (ErrorContent != null)
    {
        @ErrorContent(new TimeoutException($"JS guard '{Name}' timed out — dependency may not be available"))
    }
    else
    {
        <div class="js-guard-error mud-border-error">
            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                           Size="Size.Small"
                           Color="Color.Error"
                           OnClick="RetryGuard"
                           Class="js-guard-error-retry" />
            <MudText Typo="Typo.body2" Color="Color.Error">
                Error loading component
            </MudText>
        </div>
    }
}

@code {
    private ErrorBoundary? _errorBoundary;
    private bool _timedOut;

    /// <summary>
    /// The name of the JS guard to check, matching the name passed to registerJsGuard() in JavaScript.
    /// </summary>
    [Parameter, EditorRequired]
    public string Name { get; set; } = "";

    /// <summary>
    /// Content to render when the named JS dependency is ready.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Optional content to render when the guarded content throws an exception.
    /// If not provided, a default error UI is rendered on error.
    /// </summary>
    [Parameter]
    public RenderFragment<Exception>? ErrorContent { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !GuardService.IsReady(Name))
        {
            var ready = await GuardService.WaitForReadyAsync(JS, Name);
            _timedOut = !ready;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Resets the error boundary, allowing the guarded content to re-render.
    /// </summary>
    public void Recover() => _errorBoundary?.Recover();

    private async Task RetryGuard()
    {
        _timedOut = false;
        var ready = await GuardService.WaitForReadyAsync(JS, Name);
        _timedOut = !ready;
        StateHasChanged();
    }
}
