@using Mythetech.Framework.Components.Buttons
@using Mythetech.Framework.Enums
@attribute [Stories("Components/CopyButton")]

<Stories TComponent="MtCopyButton">

    <ArgType For="_ => _.Color" Control="ControlType.Color" />
    <ArgType For="_ => _.Class" Control="ControlType.Default" />

    <ProductStory Name="Icon" TComponent="MtCopyButton">
        <Arguments>
            <Arg For="_ => _.Text" Value="@("Hello from Mythetech.Framework")" />
            <Arg For="_ => _.CopyVariant" Value="CopyButtonVariant.Icon" />
            <Arg For="_ => _.CopyTooltip" Value="@("Copy")" />
            <Arg For="_ => _.CopiedTooltip" Value="@("Copied")" />
            <Arg For="_ => _.ErrorTooltip" Value="@("Copy failed")" />
            <Arg For="_ => _.Color" Value="Color.Default" />
            <Arg For="_ => _.Size" Value="Size.Medium" />
            <Arg For="_ => _.Variant" Value="Variant.Text" />
            <Arg For="_ => _.TooltipPlacement" Value="Placement.Bottom" />
            <Arg For="_ => _.Disabled" Value="false" />
            <Arg For="_ => _.Class" Value="@("")" />
        </Arguments>

        <Template>
            <MtCopyButton @attributes="context.Args" Class="@(context.Args["Class"]?.ToString() ?? "")" />
        </Template>
    </ProductStory>

    <ProductStory Name="Text" TComponent="MtCopyButton">
        <Arguments>
            <Arg For="_ => _.Text" Value="@("Hello from Mythetech.Framework")" />
            <Arg For="_ => _.CopyVariant" Value="CopyButtonVariant.Text" />
            <Arg For="_ => _.CopyTooltip" Value="@("Copy")" />
            <Arg For="_ => _.CopiedTooltip" Value="@("Copied")" />
            <Arg For="_ => _.ErrorTooltip" Value="@("Copy failed")" />
            <Arg For="_ => _.Color" Value="Color.Default" />
            <Arg For="_ => _.Size" Value="Size.Medium" />
            <Arg For="_ => _.Variant" Value="Variant.Text" />
            <Arg For="_ => _.Disabled" Value="false" />
            <Arg For="_ => _.Class" Value="@("")" />
        </Arguments>

        <Template>
            <MtCopyButton @attributes="context.Args" Class="@(context.Args["Class"]?.ToString() ?? "")" />
        </Template>
    </ProductStory>
</Stories>
