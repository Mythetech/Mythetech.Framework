@using Mythetech.Framework.Components.Input
@using MudBlazor
@attribute [Stories("Components/Input/MtTextField")]

<Stories TComponent="MtTextField<string>">

    <ArgType For="_ => _.Label" Control="ControlType.Default" />
    <ArgType For="_ => _.Placeholder" Control="ControlType.Default" />
    <ArgType For="_ => _.ErrorText" Control="ControlType.Default" />

    <ProductStory Name="Default" TComponent="MtTextField<string>">
        <Arguments>
            <Arg For="_ => _.Placeholder" Value="@("Enter text...")" />
            <Arg For="_ => _.Immediate" Value="true" />
        </Arguments>

        <Template>
            <MtTextField T="string" @attributes="context.Args" />
        </Template>
    </ProductStory>

    <ProductStory Name="With Label" TComponent="MtTextField<string>">
        <Arguments>
            <Arg For="_ => _.Label" Value="@("Username")" />
            <Arg For="_ => _.Placeholder" Value="@("Enter username")" />
        </Arguments>

        <Template>
            <MtTextField T="string" @attributes="context.Args" />
        </Template>
    </ProductStory>

    <ProductStory Name="With Adornment" TComponent="MtTextField<string>">
        <Arguments>
            <Arg For="_ => _.Label" Value="@("Search")" />
            <Arg For="_ => _.Placeholder" Value="@("Search...")" />
            <Arg For="_ => _.Adornment" Value="Adornment.Start" />
            <Arg For="_ => _.AdornmentIcon" Value="@Icons.Material.Filled.Search" />
        </Arguments>

        <Template>
            <MtTextField T="string" @attributes="context.Args" />
        </Template>
    </ProductStory>

    <ProductStory Name="Clearable" TComponent="MtTextField<string>">
        <Arguments>
            <Arg For="_ => _.Label" Value="@("Filter")" />
            <Arg For="_ => _.Clearable" Value="true" />
            <Arg For="_ => _.Value" Value="@("Some value")" />
        </Arguments>

        <Template>
            <MtTextField T="string" @attributes="context.Args" />
        </Template>
    </ProductStory>

    <ProductStory Name="Error State" TComponent="MtTextField<string>">
        <Arguments>
            <Arg For="_ => _.Label" Value="@("Email")" />
            <Arg For="_ => _.Value" Value="@("invalid")" />
            <Arg For="_ => _.Error" Value="true" />
            <Arg For="_ => _.ErrorText" Value="@("Please enter a valid email address")" />
        </Arguments>

        <Template>
            <MtTextField T="string" @attributes="context.Args" />
        </Template>
    </ProductStory>

    <ProductStory Name="Multiline" TComponent="MtTextField<string>">
        <Arguments>
            <Arg For="_ => _.Label" Value="@("Description")" />
            <Arg For="_ => _.Placeholder" Value="@("Enter a description...")" />
            <Arg For="_ => _.Lines" Value="4" />
        </Arguments>

        <Template>
            <MtTextField T="string" @attributes="context.Args" />
        </Template>
    </ProductStory>

    <ProductStory Name="Disabled" TComponent="MtTextField<string>">
        <Arguments>
            <Arg For="_ => _.Label" Value="@("Read Only Field")" />
            <Arg For="_ => _.Value" Value="@("Cannot edit")" />
            <Arg For="_ => _.Disabled" Value="true" />
        </Arguments>

        <Template>
            <MtTextField T="string" @attributes="context.Args" />
        </Template>
    </ProductStory>

</Stories>
