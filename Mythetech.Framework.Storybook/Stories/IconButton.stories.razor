@using Mythetech.Framework.Components.Buttons
@using Mythetech.Framework.Enums
@attribute [Stories("Components/IconButton")]

<Stories TComponent="MtIconButton">

    <ArgType For="_ => _.Color" Control="ControlType.Color" />
    <ArgType For="_ => _.Class" Control="ControlType.Default" />

    <ProductStory TComponent="MtIconButton">
        <Arguments>
            <Arg For="_ => _.Color" Value="Color.Primary" />
            <Arg For="_ => _.Variant" Value="Variant.Filled" />
            <Arg For="_ => _.Icon" Value="@(MudBlazor.Icons.Material.Rounded.ContentCopy)" />
            <Arg For="_ => _.Tooltip" Value="@("Copy")" />
            <Arg For="_ => _.TooltipPlacement" Value="Placement.Top" />
            <Arg For="_ => _.Size" Value="Size.Medium" />
            <Arg For="_ => _.Disabled" Value="false" />
            <Arg For="_ => _.Class" Value="@("")" />
        </Arguments>

        <Template>
            <MtIconButton @attributes="context.Args" Class="@(context.Args["Class"]?.ToString() ?? "")">
            </MtIconButton>
        </Template>
    </ProductStory>
</Stories>