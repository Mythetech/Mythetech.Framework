@using Mythetech.Framework.Components.Input
@using MudBlazor
@attribute [Stories("Components/Input/MtNumericField")]

<Stories TComponent="MtNumericField<int>">

    <ArgType For="_ => _.Label" Control="ControlType.Default" />
    <ArgType For="_ => _.Placeholder" Control="ControlType.Default" />
    <ArgType For="_ => _.ErrorText" Control="ControlType.Default" />

    <ProductStory Name="Default" TComponent="MtNumericField<int>">
        <Arguments>
            <Arg For="_ => _.Placeholder" Value="@("Enter a number")" />
        </Arguments>

        <Template>
            <MtNumericField T="int" @attributes="context.Args" />
        </Template>
    </ProductStory>

    <ProductStory Name="With Label" TComponent="MtNumericField<int>">
        <Arguments>
            <Arg For="_ => _.Label" Value="@("Quantity")" />
            <Arg For="_ => _.Value" Value="@((int?)1)" />
        </Arguments>

        <Template>
            <MtNumericField T="int" @attributes="context.Args" />
        </Template>
    </ProductStory>

    <ProductStory Name="With Adornment" TComponent="MtNumericField<int>">
        <Arguments>
            <Arg For="_ => _.Label" Value="@("Amount")" />
            <Arg For="_ => _.Value" Value="@((int?)11)" />
            <Arg For="_ => _.Adornment" Value="Adornment.Start" />
            <Arg For="_ => _.AdornmentIcon" Value="@Icons.Material.Filled.AttachMoney" />
        </Arguments>

        <Template>
            <MtNumericField T="int" @attributes="context.Args" />
        </Template>
    </ProductStory>

    <ProductStory Name="Min Max Bounds" TComponent="MtNumericField<int>">
        <Arguments>
            <Arg For="_ => _.Label" Value="@("Rating (1-5)")" />
            <Arg For="_ => _.Value" Value="@((int?)3)" />
            <Arg For="_ => _.Min" Value="@((int?)1)" />
            <Arg For="_ => _.Max" Value="@((int?)5)" />
        </Arguments>

        <Template>
            <MtNumericField T="int" @attributes="context.Args" />
        </Template>
    </ProductStory>

    <ProductStory Name="Custom Step" TComponent="MtNumericField<int>">
        <Arguments>
            <Arg For="_ => _.Label" Value="@("Temperature")" />
            <Arg For="_ => _.Value" Value="@((int?)99)" />
            <Arg For="_ => _.Step" Value="@((int?)5)" />
        </Arguments>

        <Template>
            <MtNumericField T="int" @attributes="context.Args" />
        </Template>
    </ProductStory>

    <ProductStory Name="Error State" TComponent="MtNumericField<int>">
        <Arguments>
            <Arg For="_ => _.Label" Value="@("Age")" />
            <Arg For="_ => _.Value" Value="@((int?)-1)" />
            <Arg For="_ => _.Error" Value="true" />
            <Arg For="_ => _.ErrorText" Value="@("Must be a positive number")" />
        </Arguments>

        <Template>
            <MtNumericField T="int" @attributes="context.Args" />
        </Template>
    </ProductStory>

    <ProductStory Name="Disabled" TComponent="MtNumericField<int>">
        <Arguments>
            <Arg For="_ => _.Label" Value="@("Fixed Value")" />
            <Arg For="_ => _.Value" Value="@((int?)42)" />
            <Arg For="_ => _.Disabled" Value="true" />
        </Arguments>

        <Template>
            <MtNumericField T="int" @attributes="context.Args" />
        </Template>
    </ProductStory>

    <ProductStory Name="Clearable" TComponent="MtNumericField<int>">
        <Arguments>
            <Arg For="_ => _.Label" Value="@("Optional")" />
            <Arg For="_ => _.Value" Value="@((int?)7)" />
            <Arg For="_ => _.Clearable" Value="true" />
        </Arguments>

        <Template>
            <MtNumericField T="int" @attributes="context.Args" />
        </Template>
    </ProductStory>

</Stories>
