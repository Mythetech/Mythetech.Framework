@using Mythetech.Framework.Components.Buttons
@using Mythetech.Framework.Enums
@attribute [Stories("Components/Button")]

<Stories TComponent="MtButton">

    <ArgType For="_ => _.Color" Control="ControlType.Color"/>
    <ArgType For="_ => _.Class" Control="ControlType.Default" />

    <ProductStory TComponent="MtButton">
        <Arguments>
            <Arg For="_ => _.Color" Value="Color.Primary"/>
            <Arg For="_ => _.Variant" Value="Variant.Filled" />
            <Arg For="_ => _.Text" Value="@("Button")" />
            <Arg For="_ => _.Class" Value="@("")" />
            <Arg For="_ => _.Roundedness" Value="Roundedness.Large" />
        </Arguments>

        <Template>
            <MtButton @attributes="context.Args" Class="@(context.Args["Class"]?.ToString() ?? "")">
            </MtButton>
        </Template>
    </ProductStory>
</Stories>